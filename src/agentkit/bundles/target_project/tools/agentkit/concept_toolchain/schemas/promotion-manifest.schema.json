{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentkit.dev/schemas/concept-toolchain/promotion-manifest.schema.json",
  "title": "promotion/promotion-manifest.json \u2014 promotion closure carrier (FK-78 section 78.11)",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "base_revision",
    "scopes",
    "required_decision_ids",
    "required_concept_ids",
    "required_formal_ids",
    "required_registry_edges",
    "required_support_paths",
    "required_test_oracles",
    "targets",
    "receipts_dir",
    "scope_locks",
    "semantic_gates"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(-[a-z0-9]+)*-[0-9a-f]{8}$"
    },
    "base_revision": {
      "type": "object",
      "required": [
        "kind",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "git",
            "digest"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scope_id",
          "promotion_disposition",
          "blockers"
        ],
        "additionalProperties": false,
        "properties": {
          "scope_id": {
            "type": "string",
            "minLength": 1
          },
          "promotion_disposition": {
            "type": "string",
            "enum": [
              "promoted",
              "rejected",
              "deferred"
            ]
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "reason",
                "atom_ids",
                "owner",
                "visible_anchor"
              ],
              "additionalProperties": false,
              "properties": {
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "atom_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^ATM-[0-9a-f]{8}-\\d{4,}$"
                  }
                },
                "owner": {
                  "type": "string",
                  "minLength": 1
                },
                "visible_anchor": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "required_decision_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_concept_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_formal_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_registry_edges": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "pattern": "^.+#.+$"
          },
          {
            "type": "object",
            "required": [
              "from",
              "to",
              "kind"
            ],
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "enum": [
                  "owns",
                  "defers_to",
                  "contract",
                  "member",
                  "producer",
                  "consumer"
                ]
              }
            }
          }
        ]
      }
    },
    "required_support_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_test_oracles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "oracle_id",
          "kind",
          "locator"
        ],
        "additionalProperties": false,
        "properties": {
          "oracle_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "before_sha256",
          "after_sha256"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "before_sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9a-f]{64}$"
          },
          "after_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "receipts_dir": {
      "type": "string",
      "minLength": 1
    },
    "scope_locks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scope_id",
          "locked_by_run",
          "fencing_token",
          "backend"
        ],
        "additionalProperties": false,
        "properties": {
          "scope_id": {
            "type": "string",
            "minLength": 1
          },
          "locked_by_run": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(-[a-z0-9]+)*-[0-9a-f]{8}$"
          },
          "fencing_token": {
            "type": "integer",
            "minimum": 1
          },
          "backend": {
            "type": "string",
            "enum": [
              "filesystem",
              "git-remote"
            ]
          }
        }
      }
    },
    "semantic_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gate",
          "status",
          "receipt_path",
          "blocking_scope_ids"
        ],
        "additionalProperties": false,
        "properties": {
          "gate": {
            "type": "string",
            "enum": [
              "authority-prose",
              "scope-consistency"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "blocked",
              "not_run"
            ]
          },
          "receipt_path": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "blocking_scope_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
