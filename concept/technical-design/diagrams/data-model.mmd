    ProjectSpace                   ||--o{ Story                          : "owns"
    ProjectSpace                   ||--o{ StoryCustomFieldDefinition     : "scopes"
    ProjectSpace                   ||--o{ KpiProjection                  : "aggregates"
    Story                          ||--|| StoryContext                   : "snapshot"
