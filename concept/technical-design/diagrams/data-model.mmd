    FlowExecution                  ||--o{ NodeExecution                  : "node-ledger"
    FlowExecution                  ||--o{ AttemptRecord                  : "phase-audit"
    FlowExecution                  ||--o{ OverrideRecord                 : "received"
    FlowExecution                  ||--o{ GuardDecision                  : "yielded"
