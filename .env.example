#
# AgentKit 3 production configuration template
#
# Production state backend:
# - PostgreSQL on the host-native standard port 5432.
# - Port 5432 is reserved exclusively for the operator's native/host-installed
#   PostgreSQL.
# - AK3 does not run or provision its own Docker Postgres on port 5432.
# - Tests use non-standard, ephemeral ports only; see
#   tests/fixtures/postgres_backend.py.
#
# Replace CHANGE_ME with the operator-managed database password. This is a
# placeholder, not a real secret.
AGENTKIT_STATE_BACKEND=postgres
AGENTKIT_STATE_DATABASE_URL=postgresql://agentkit:CHANGE_ME@localhost:5432/agentkit

# SQLite is a gated, narrow unit-test fallback only. It is disabled for
# runtime/build/contract/integration/e2e paths unless explicitly allowed by the
# test gate in agentkit.config.sqlite_gate.
# AGENTKIT_STATE_BACKEND=sqlite
